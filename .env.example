BOT_TOKEN=

DATABASE_URL=postgresql+asyncpg://digest:digest@postgres:5432/digest_bot

# local | openai
AI_PROVIDER=local

LOCAL_AI_BASE_URL=http://178.170.249.108:40000
LOCAL_AI_MODEL=openai/gpt-oss-20b

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=

# Telethon (required for reading public channels)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Legacy optional reader session (not used for per-user subscriptions)
TELEGRAM_SESSION_STRING=

# Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SESSION_ENCRYPTION_KEY=

# Optional proxy for Telethon (socks5://user:pass@host:port or http://...)
TELEGRAM_PROXY_URL=

# Optional — use if Telegram API is blocked (e.g. http://user:pass@host:port)
BOT_PROXY_URL=
BOT_API_TIMEOUT=60

LOG_LEVEL=INFO
MAX_MESSAGES_PER_SOURCE=30

# Single AI request per digest (gpt-oss needs room for reasoning + answer)
AI_MAX_CONTEXT_TOKENS=8192
AI_MAX_OUTPUT_TOKENS=2048
AI_REASONING_EFFORT=low
AI_MAX_MESSAGES_TO_SCORE=20
AI_SCORE_MESSAGE_MAX_CHARS=350
AI_MIN_MESSAGE_CHARS=40

# Schedule & catalog
DEFAULT_TIMEZONE=Europe/Moscow
CATALOG_CHANNELS=@ai_news:AI News,@python:Python,@openai:OpenAI
