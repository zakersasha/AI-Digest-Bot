BOT_TOKEN=

DATABASE_URL=postgresql+asyncpg://digest:digest@postgres:5432/digest_bot

# AI: local (self-hosted) or openai (OpenAI API)
# local  — gpt-oss / vLLM, small context
# openai — cheap cloud model, more channels & posts (needs OPENAI_API_KEY)
AI_PROVIDER=local

# --- Local model ---
LOCAL_AI_BASE_URL=http://178.170.249.108:40000
LOCAL_AI_MODEL=openai/gpt-oss-20b
AI_MAX_CONTEXT_TOKENS=4096
AI_MAX_OUTPUT_TOKENS=2048
AI_REASONING_EFFORT=low
AI_MAX_MESSAGES_TO_SCORE=20
AI_SCORE_MESSAGE_MAX_CHARS=300

# --- OpenAI API (set AI_PROVIDER=openai) ---
OPENAI_API_KEY=
# Optional second key — rotates with OPENAI_API_KEY; used on errors (429/5xx/timeout)
OPENAI_API_KEY_2=
OPENAI_MODEL=gpt-4o-mini
# Leave unset for https://api.openai.com/v1 — do not set OPENAI_BASE_URL= (empty breaks requests)
# Proxies paired by index: slot 1 = KEY + PROXY_URL, slot 2 = KEY_2 + PROXY_URL_2
# If OPENAI_PROXY_URL is empty, falls back to TELEGRAM_PROXY_URL / BOT_PROXY_URL
OPENAI_PROXY_URL=
OPENAI_PROXY_URL_2=
AI_OPENAI_MAX_CONTEXT_TOKENS=32000
AI_OPENAI_MAX_OUTPUT_TOKENS=4096
AI_OPENAI_MAX_MESSAGES=50
AI_OPENAI_MESSAGE_MAX_CHARS=500

AI_MIN_MESSAGE_CHARS=40

# Telethon (required for reading public channels)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=

# Any long secret string (encrypts Gmail/Telethon tokens in DB)
SESSION_ENCRYPTION_KEY=change-me-to-a-long-random-secret

TELEGRAM_PROXY_URL=
BOT_PROXY_URL=
BOT_API_TIMEOUT=60

LOG_LEVEL=INFO
MAX_MESSAGES_PER_SOURCE=30

DEFAULT_TIMEZONE=Europe/Moscow
CATALOG_CHANNELS=@ai_news:AI News,@python:Python,@openai:OpenAI

# Gmail OAuth (read-only inbox digests)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
# MUST match Google Cloud → OAuth client → Authorized redirect URIs exactly
GMAIL_REDIRECT_URI=https://brieflybot.pro/oauth/gmail/callback
# Optional; auto-detected from bot if empty
BOT_USERNAME=
GMAIL_OAUTH_HOST=0.0.0.0
GMAIL_OAUTH_PORT=8080
GMAIL_MAX_MESSAGES=50

# Slack OAuth (channel digests — user token with history scopes)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=https://brieflybot.pro/oauth/slack/callback
SLACK_MAX_MESSAGES=50

# LinkedIn OAuth (Sign In + optional Community Management API)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://brieflybot.pro/oauth/linkedin/callback
LINKEDIN_PROXY_URL=
LINKEDIN_MAX_POSTS=30
# Optional extra scopes if approved (e.g. r_organization_social)
LINKEDIN_EXTRA_SCOPES=

# Google Custom Search — discovers public LinkedIn post URLs (100 free queries/day)
# Create: https://programmablesearchengine.google.com/ + Cloud API key
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=
